---
import Base from "@/layouts/Base.astro";
import IntegrationList from "@/components/IntegrationList";
import CallToAction from "@/partials/CallToAction";
import FAQ from "@/partials/FAQ";
import PageHeader from "@/partials/PageHeader";
import { getListPage, getSinglePage } from "@/lib/contentParser";

const integrationIndex = await getListPage("integrations/-index.md");
const { title, description, meta_title, image, page_header } = integrationIndex.frontmatter;
const integrations_list = await getSinglePage("integrations");
const faq = await getListPage("sections/faq.md");
const callToAction = await getListPage("sections/call-to-action.md");
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <PageHeader page_header={page_header} client:load />
  <IntegrationList integration_list={integrations_list} client:load />
  <FAQ data={faq} client:visible />
  <CallToAction data={callToAction} client:visible />
</Base>
