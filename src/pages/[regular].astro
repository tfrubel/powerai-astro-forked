---
import Base from "@/layouts/Base.astro";
import MainContainer from "@/components/MainContainer";
import MDXContent from "@/helpers/MDXContent";
import PageHeader from "@/partials/PageHeader";
import { getSinglePage } from "@/lib/contentParser";

export async function getStaticPaths() {
  const pages = await getSinglePage("pages");
  return pages.map((page: any) => ({
    params: { regular: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { frontmatter, content } = page;
const { title, meta_title, description, image, page_header } = frontmatter;
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  {page_header && <PageHeader page_header={page_header} client:load />}
  <section>
    <MainContainer>
      <div class="container-padding-x container-padding-y">
        <div class="content">
          <MDXContent content={content} client:load />
        </div>
      </div>
    </MainContainer>
  </section>
</Base>
