---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero";
import Statistics from "@/components/Statistics";
import CallToAction from "@/partials/CallToAction";
import EssentialFeatures from "@/partials/EssentialFeatures";
import FAQ from "@/partials/FAQ";
import Integration from "@/partials/Integration";
import KeyFeatures from "@/partials/KeyFeatures";
import Pricing from "@/partials/Pricing";
import Testimonials from "@/partials/Testimonials";
import TrustedClients from "@/partials/TrustedClients";
import WhyChooseUs from "@/partials/WhyChooseUs";
import { getListPage } from "@/lib/contentParser";

const homepage = await getListPage("homepage/-index.md");
const trusted_clients = await getListPage("sections/trusted-clients.md");
const key_features = await getListPage("sections/key-features.md");
const essential_features = await getListPage("sections/essential-features.md");
const whyChooseUs = await getListPage("sections/why-choose-us.md");
const integration = await getListPage("sections/integration.md");
const pricing = await getListPage("sections/pricing.md");
const testimonial = await getListPage("sections/testimonial.md");
const faq = await getListPage("sections/faq.md");
const callToAction = await getListPage("sections/call-to-action.md");
const statistics = await getListPage("sections/statistics.md");
const { banner } = homepage.frontmatter;
---

<Base>
  <Hero data={banner} client:load />
  <TrustedClients data={trusted_clients} client:load />
  <KeyFeatures data={key_features} client:load />
  <Statistics data={statistics} client:visible />
  <EssentialFeatures data={essential_features} client:visible />
  <WhyChooseUs data={whyChooseUs} client:visible />
  <Integration data={integration} client:visible />
  <Pricing data={pricing} client:visible />
  <Testimonials data={testimonial} client:visible />
  <FAQ data={faq} client:visible />
  <CallToAction data={callToAction} client:visible />
</Base>
