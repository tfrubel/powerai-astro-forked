---
interface Props {
  title: string;
  className?: string;
}
const { title, className = "" } = Astro.props;
const uid = `accordion-${Math.random().toString(36).slice(2, 8)}`;
---

<div id={uid} class={`accordion ${className}`}>
  <button class="accordion-header">
    {title}
    <svg class="accordion-icon" viewBox="0 0 512 512">
      <path fill="currentColor" d="M505.755,123.592c-8.341-8.341-21.824-8.341-30.165,0L256.005,343.176L36.421,123.592c-8.341-8.341-21.824-8.341-30.165,0s-8.341,21.824,0,30.165l234.667,234.667c4.16,4.16,9.621,6.251,15.083,6.251c5.462,0,10.923-2.091,15.083-6.251l234.667-234.667C514.096,145.416,514.096,131.933,505.755,123.592z"/>
    </svg>
  </button>
  <div class="accordion-content">
    <slot />
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".accordion-header").forEach((btn) => {
      btn.addEventListener("click", () => {
        const accordion = btn.closest(".accordion");
        if (accordion) accordion.classList.toggle("active");
      });
    });
  });
</script>
