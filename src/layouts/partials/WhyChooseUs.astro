---
import IconBox from "@/components/IconBox.astro";
import SectionHeader from "@/components/SectionHeader.astro";
interface Props {
  data: any;
}
const { data } = Astro.props;
const { badge, title, feature_list, enable } = data.frontmatter;
---

{enable && (
  <section>
    <div class="main-container">
      <div class="container">
        <div class="container-padding-y container-padding-x">
          <SectionHeader title={title} badge={badge} />
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-14 md:gap-25 relative overflow-hidden">
            {feature_list.map((item: any) => {
              const uid = `wcu-${Math.random().toString(36).slice(2, 8)}`;
              return (
                <div id={uid} style="opacity:0">
                  <IconBox icon={item.icon} />
                  <h3 class="text-h5 font-medium mb-5">{item.title}</h3>
                  <p class="text-gray">{item.content}</p>
                </div>
              );
            })}
            <!-- Grid lines -->
            <div class="hidden md:block absolute top-0 left-[calc(50%-10px)] lg:left-[calc(33.3333%-20px)]">
              <svg width="1" height="590" viewBox="0 0 1 590" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="1" height="590" fill="url(#wcu_hl1)"/><defs><linearGradient id="wcu_hl1" x1="0.5" y1="0" x2="0.5" y2="590" gradientUnits="userSpaceOnUse"><stop stop-color="white" stop-opacity="0"/><stop offset="0.35" stop-color="white" stop-opacity="0.1"/><stop offset="0.65" stop-color="white" stop-opacity="0.1"/><stop offset="1" stop-color="white" stop-opacity="0"/></linearGradient></defs></svg>
            </div>
            <div class="hidden md:block absolute top-1/2 lg:top-0 left-[calc(50%-10px)] lg:left-[calc(66.6666%+20px)]">
              <svg width="1" height="590" viewBox="0 0 1 590" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="1" height="590" fill="url(#wcu_hl2)"/><defs><linearGradient id="wcu_hl2" x1="0.5" y1="0" x2="0.5" y2="590" gradientUnits="userSpaceOnUse"><stop stop-color="white" stop-opacity="0"/><stop offset="0.35" stop-color="white" stop-opacity="0.1"/><stop offset="0.65" stop-color="white" stop-opacity="0.1"/><stop offset="1" stop-color="white" stop-opacity="0"/></linearGradient></defs></svg>
            </div>
            <div class="hidden md:block absolute left-0 top-1/3 lg:top-1/2 -translate-y-1/3 lg:-translate-y-1/2">
              <svg width="1188" height="1" viewBox="0 0 1188 1" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 0H1188V1H0V0Z" fill="url(#wcu_vl1)"/><defs><linearGradient id="wcu_vl1" x1="-0.00991344" y1="0.504736" x2="1187.99" y2="0.504736" gradientUnits="userSpaceOnUse"><stop stop-color="white" stop-opacity="0"/><stop offset="0.2" stop-color="white" stop-opacity="0.1"/><stop offset="0.8" stop-color="white" stop-opacity="0.1"/><stop offset="1" stop-color="white" stop-opacity="0"/></linearGradient></defs></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  import { animateMini as animate, inView } from "motion";
  function initWhyChooseUs() {
    document.querySelectorAll<HTMLElement>('[id^="wcu-"]').forEach((el, i) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut", delay: i * 0.1 });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initWhyChooseUs);
</script>
